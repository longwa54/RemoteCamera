<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- Glow/Dim Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/bottom_gradient_overlay"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Info Overlay Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Title and Status -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMOTE RECEIVER"
            android:textColor="@color/primary_neon"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <View
                android:id="@+id/statusIndicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_indicator_red" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Listening on port 8888..."
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="IP: Retrieving..."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="italic" />

        <!-- Log Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="EVENT LOGS"
            android:textColor="@color/accent_neon"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Scrollable log output -->
        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="6dp"
            android:background="#A6000000"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="[System] Service initialized.\n"
                android:textColor="#00FF66"
                android:fontFamily="monospace"
                android:textSize="11sp" />
        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
