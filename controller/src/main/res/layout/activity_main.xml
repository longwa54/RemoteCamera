<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="16dp">

    <!-- Header Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="远程相机控制端"
        android:textColor="@color/primary_neon"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- Status indicator & text -->
    <LinearLayout
        android:id="@+id/statusLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintLeft_toLeftOf="parent">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_indicator_red" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="未连接"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Discovered Devices Section -->
    <TextView
        android:id="@+id/tvDiscoveredTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="局域网发现设备"
        android:textColor="@color/accent_neon"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/statusLayout"
        app:layout_constraintLeft_toLeftOf="parent" />

    <HorizontalScrollView
        android:id="@+id/svDevices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvDiscoveredTitle">
        
        <LinearLayout
            android:id="@+id/containerDiscoveredDevices"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Manual Connection Layout -->
    <LinearLayout
        android:id="@+id/manualLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/svDevices">

        <EditText
            android:id="@+id/etIp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.8"
            android:hint="被控端 IP 地址"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@drawable/edittext_background"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/etPort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:layout_marginStart="8dp"
            android:hint="8888"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@drawable/edittext_background"
            android:inputType="number" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="连接"
            android:textColor="@color/black"
            android:backgroundTint="@color/primary_neon"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Viewfinder Viewport -->
    <FrameLayout
        android:id="@+id/frameViewport"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/viewport_background"
        app:layout_constraintTop_toBottomOf="@id/manualLayout"
        app:layout_constraintBottom_toTopOf="@id/shutterLayout">

        <ImageView
            android:id="@+id/ivPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:adjustViewBounds="true" />

        <TextView
            android:id="@+id/tvViewportPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂未接收到画面"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1" />

        <!-- Grid Lines for Viewport -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center_vertical"
            android:background="#1affffff" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="#1affffff" />
    </FrameLayout>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/shutterLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnShutter"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/shutter_button_background"
            android:contentDescription="拍摄"
            android:scaleType="centerInside" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="保存照片"
        android:textColor="@color/white"
        android:backgroundTint="@color/accent_neon"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/shutterLayout"
        app:layout_constraintTop_toTopOf="@id/shutterLayout"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
